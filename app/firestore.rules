rules_version = '2';

// ═══════════════════════════════════════════════════════════
//  ArogyaSathi — Firestore Security Rules
//  v2: Supports Patient/Caregiver roles with cross-user access
//
//  Rules:
//    - Users can read/write their own data
//    - Caregivers can read/write linked patient's medications
//    - Caregivers can read linked patient's history and alerts
//    - Share-code lookup requires auth (read-only on users collection)
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: Is the request from an authenticated user? ──
    function isAuth() {
      return request.auth != null;
    }

    // ── Helper: Does the user own this document path? ──
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── Helper: Is the current user a linked caregiver for this patient? ──
    function isLinkedCaregiver(patientId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(patientId)) &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(patientId)).data.linked_caregivers;
    }

    // ════════════════════════════════════════════════
    //  /users/{userId} — User Profile Root
    //  Owner: full access
    //  Other authenticated users: read-only (for share-code lookup)
    // ════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isOwner(userId);

      // ── Medications (reminders) ─────────────────
      // Owner OR linked caregiver can read/write
      match /medications/{docId} {
        allow read, write: if isOwner(userId) || isLinkedCaregiver(userId);
      }

      // ── Medication History (adherence logs) ─────
      // Owner: read/write. Caregiver: read only
      match /history/{docId} {
        allow read: if isOwner(userId) || isLinkedCaregiver(userId);
        allow write: if isOwner(userId);
      }

      // ── Pill Inventory ──────────────────────────
      match /inventory/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── Caregivers / Care Team ──────────────────
      match /caregivers/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── SOS Alerts ─────────────────────────────
      // Owner: read/write. Caregiver: read only
      match /alerts/{docId} {
        allow read: if isOwner(userId) || isLinkedCaregiver(userId);
        allow write: if isOwner(userId);
      }

      // ── Appointments ───────────────────────────
      match /appointments/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── Medical ID (basic_health, conditions, emergency_contacts) ──
      match /medical_id/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ── Health Records ─────────────────────────
      match /records/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ════════════════════════════════════════════════
    //  /alarm_schedules/{docId} — Cross-User Alarm Timing
    //  Doc ID format: {uid}_{alarmId}
    //  Owner can read/write. All authenticated users can read
    //  (for hardware/admin dashboard to query all alarms).
    // ════════════════════════════════════════════════
    match /alarm_schedules/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && resource == null
          ? request.auth.uid == request.resource.data.uid
          : request.auth.uid == resource.data.uid;
    }

    // ════════════════════════════════════════════════
    //  /hardware_control/{deviceId} — ESP32 IoT Devices
    //  Any authenticated user (app or device) can read/write.
    // ════════════════════════════════════════════════
    match /hardware_control/{deviceId} {
      allow read, write: if isAuth();
    }

    // ════════════════════════════════════════════════
    //  DEFAULT: Deny everything else
    // ════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
